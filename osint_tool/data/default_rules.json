          "attr": "href"
        },
        {
          "type": "xpath",
          "identity_type": "url",
          "expr": "//div[contains(@class,'profile_summary')]//a/@href"
        },
        {
          "type": "regex",
          "identity_type": "url",
          "pattern": "https?://(?:www\\.)?(?:twitter|x)\\.com/([\\w]{1,50})",
          "group": 0,
          "hint_platform": "Twitter/X"
        },
        {
          "type": "regex",
          "identity_type": "url",
          "pattern": "https?://(?:www\\.)?youtube\\.com/@([\\w-]{3,30})",
          "group": 0,
          "hint_platform": "YouTube"
